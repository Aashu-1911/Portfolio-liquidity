# Environment Configuration Template
# Copy this file to .env and fill in your values

# ══════════════════════════════════════════════════════════════════════════════
# OpenAI API Configuration (Optional - for LLM features)
# ══════════════════════════════════════════════════════════════════════════════
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ══════════════════════════════════════════════════════════════════════════════
# Flask Configuration
# ══════════════════════════════════════════════════════════════════════════════
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# ══════════════════════════════════════════════════════════════════════════════
# Data Configuration
# ══════════════════════════════════════════════════════════════════════════════
# Number of symbols to fetch (None = all S&P 500, or set to 50 for testing)
SYMBOL_LIMIT=

# Historical data period (1y, 2y, 5y, 10y, max)
HISTORICAL_PERIOD=5y

# ══════════════════════════════════════════════════════════════════════════════
# Pipeline Configuration
# ══════════════════════════════════════════════════════════════════════════════
# Time to run daily pipeline (HH:MM format, 24-hour)
PIPELINE_RUN_TIME=17:00

# ══════════════════════════════════════════════════════════════════════════════
# Logging Configuration
# ══════════════════════════════════════════════════════════════════════════════
LOG_LEVEL=INFO
